{
  "compilerOptions": {
    "target": "es6",
    "module": "ESNext",
    "rootDir": "./",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "allowJs": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "strict": true,
    "types": ["node", "vitest"]
  },
  "include": ["src", "**/*.js", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
