{
  "name": "email-service",
  "version": "1.0.0",
  "description": "A Node.js microservice for sending templated emails via AWS SQS. Consumes messages from SQS queues, fetches email templates from database, renders with Handlebars, and sends via AWS SES or SMTP.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "lint": "eslint src",
    "lint-staged": "lint-staged",
    "prettier-check": "prettier --check .",
    "prettier-fix": "prettier --write .",
    "start": "npm run dbm:up && tsc --project tsconfig.build.json && node dist/src/index.js",
    "dev": "nodemon src/index.ts",
    "test": "jest",
    "test-watch": "jest --verbose --watchAll --no-cache --runInBand",
    "tsc-check": "tsc --noEmit",
    "dbs:up": "npx sequelize-cli db:seed:all --env dbData",
    "dbm:create": "npx sequelize-cli migration:generate --env dbData --name",
    "dbm:up": "npx sequelize-cli db:migrate --env dbData",
    "dbm:down": "npx sequelize-cli db:migrate:undo --env dbData"
  },
  "jest": {
    "testEnvironment": "node",
    "preset": "ts-jest",
    "setupFilesAfterEnv": [
      "./src/testUtils/setupAfterEnv.ts"
    ]
  },
  "keywords": [
    "email-service",
    "aws-sqs",
    "aws-ses",
    "smtp",
    "nodemailer",
    "typescript",
    "email-templates",
    "handlebars",
    "sequelize",
    "express",
    "microservice",
    "queue",
    "transactional-email",
    "datadog",
    "multi-tenant"
  ],
  "author": "Or Assayag <orassayag@gmail.com> (https://github.com/orassayag)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/orassayag/email-service.git"
  },
  "bugs": {
    "url": "https://github.com/orassayag/email-service/issues"
  },
  "homepage": "https://github.com/orassayag/email-service#readme",
  "dependencies": {
    "@aws-sdk/client-ses": "3.238.0",
    "@aws-sdk/client-sqs": "3.231.0",
    "@datadog/datadog-api-client": "^1.6.0",
    "body-parser": "1.20.1",
    "express": "^4.18.2",
    "express-async-errors": "3.1.1",
    "express-validator": "6.9.2",
    "handlebars": "4.7.7",
    "mariadb": "3.0.2",
    "mysql2": "^2.3.3",
    "nodemailer": "6.8.0",
    "nodemon": "2.0.20",
    "sequelize": "6.27.0",
    "sequelize-cli": "^6.5.2",
    "sqs-consumer": "6.0.2",
    "ts-node": "9.1.1",
    "typescript": "4.1.3",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "@types/express": "4.17.11",
    "@types/node": "14.14.25",
    "@types/nodemailer": "6.4.0",
    "@types/sequelize": "^4.28.14",
    "@types/sinon": "10.0.13",
    "@types/supertest": "2.0.10",
    "@typescript-eslint/eslint-plugin": "4.14.2",
    "@typescript-eslint/parser": "4.14.2",
    "eslint": "7.19.0",
    "eslint-config-airbnb-typescript": "12.0.0",
    "eslint-config-prettier": "6.15.0",
    "eslint-plugin-import": "2.22.1",
    "eslint-plugin-prettier": "3.3.1",
    "jest": "26.6.3",
    "jest-when": "3.5.2",
    "lint-staged": "10.5.3",
    "prettier": "2.2.1",
    "sinon": "15.0.1",
    "supertest": "6.1.3",
    "ts-jest": "26.5.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "npm run prettier:fix",
      "npm run lint",
      "git add"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged && npm run test"
    }
  }
}
